# Browser → API base (production or when not using Vite proxy). No trailing slash.
# VITE_API_BASE=https://your-api.example.com

# Vite dev server only: where to proxy /api (default http://127.0.0.1:8787).
# If the backend printed a different port (8787 busy), match it here:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8788
