{
  "name": "twinmind-meeting-copilot-api",
  "version": "1.0.0",
  "description": "Express API for TwinMind AI meeting copilot (Groq Whisper + chat)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch . --ext js,json --ignore node_modules --ignore ../node_modules --ignore ../frontend --ignore \"**/*.log\" server.js"
  },
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "iconv-lite": "^0.7.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
